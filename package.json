{
  "name": "agent-k",
  "version": "0.1.0",
  "description": "Standalone Tauri desktop client for the Pi coding agent",
  "private": true,
  "type": "module",
  "workspaces": [
    "extensions/k-plan"
  ],
  "scripts": {
    "clean": "shx rm -rf dist",
    "dev": "vite",
    "build": "tsc -b && vite build",
    "check": "npm run check:web && npm run check:k-plan",
    "check:web": "tsc -b",
    "check:k-plan": "tsc -p extensions/k-plan/tsconfig.json",
    "check:desktop": "cargo check --manifest-path src-tauri/Cargo.toml",
    "test": "node --test extensions/k-plan/index.test.ts",
    "preview": "vite preview",
    "tauri": "tauri"
  },
  "dependencies": {
    "@fontsource-variable/noto-sans-sc": "5.2.10",
    "@fortawesome/fontawesome-free": "7.3.1",
    "@monaco-editor/react": "4.7.0",
    "@tauri-apps/api": "2.11.1",
    "@tauri-apps/plugin-dialog": "2.7.2",
    "@tauri-apps/plugin-opener": "2.5.4",
    "katex": "0.18.0",
    "lucide-react": "1.25.0",
    "monaco-editor": "0.55.1",
    "react": "19.1.1",
    "react-dom": "19.1.1",
    "react-markdown": "10.1.0",
    "rehype-katex": "7.0.1",
    "remark-breaks": "4.0.0",
    "remark-gfm": "4.0.1",
    "remark-math": "6.0.0"
  },
  "devDependencies": {
    "@earendil-works/pi-coding-agent": "0.80.10",
    "@tauri-apps/cli": "2.11.4",
    "@types/node": "24.6.0",
    "@types/react": "19.1.10",
    "@types/react-dom": "19.1.7",
    "@vitejs/plugin-react": "5.0.2",
    "shx": "0.4.0",
    "typescript": "5.9.2",
    "vite": "7.1.7"
  },
  "engines": {
    "node": ">=22.19.0"
  }
}
