{
  "apiVersion": 1,
  "id": "agent-k.image",
  "name": "Image preview",
  "match": {
    "extensions": ["png", "jpg", "jpeg", "gif", "webp", "bmp", "ico", "svg"],
    "mimeTypes": ["image/*"]
  },
  "editor": "plugin",
  "mediaKind": "image",
  "runtime": { "entry": "dist/editor.iife.js", "menu": "dist/menu.iife.js", "style": "dist/editor.css" }
}
