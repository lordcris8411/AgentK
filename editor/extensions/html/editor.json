{
  "apiVersion": 1,
  "id": "agent-k.html",
  "name": "HTML",
  "match": { "extensions": ["html", "htm"], "mimeTypes": ["text/html"] },
  "editor": "plugin",
  "editable": true,
  "languageId": "html",
  "runtime": { "dependencies": ["monaco-editor@0.55.1"], "entry": "dist/editor.iife.js", "menu": "dist/menu.iife.js", "style": "dist/editor.css" },
  "capabilities": [
    {
      "id": "capture-preview",
      "label": "Capture preview",
      "description": "Save the currently visible HTML preview as a PNG image."
    }
  ]
}
